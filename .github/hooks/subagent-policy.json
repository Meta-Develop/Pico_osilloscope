{
  "hooks": {
    "PreToolUse": [
      {
        "type": "command",
        "command": "pwsh -NoProfile -File .github/hooks/enforce-subagent-policy.ps1",
        "timeout": 10
      }
    ],
    "SubagentStart": [
      {
        "type": "command",
        "command": "pwsh -NoProfile -File .github/hooks/enforce-subagent-policy.ps1",
        "timeout": 10
      }
    ]
  }
}
